LINGUAGEM PYTHON

# Entrada da quantidade de alunos
qtd_alunos = int(input("Quantos alunos existem na turma? "))

soma_notas = 0
aprovados = 0
recuperacao = 0
reprovados = 0

for i in range(1, qtd_alunos + 1):
    nota = float(input(f"Digite a nota do aluno {i}: "))
    soma_notas += nota
    
    # Classificação
    if nota >= 7:
        aprovados += 1
    elif 5 <= nota < 7:
        recuperacao += 1
    else:
        reprovados += 1

# Cálculos finais
media = soma_notas / qtd_alunos if qtd_alunos > 0 else 0

print("-" * 30)
print(f"Média da turma: {media:.2f}")
print(f"Aprovados (>= 7): {aprovados}")
print(f"Recuperação (5 a 6.9): {recuperacao}")
print(f"Reprovados (< 5): {reprovados}")

LINGUAGEM C

#include <stdio.h>

int main() {
    int qtd_alunos;
    float nota, soma_notas = 0, media;
    int aprovados = 0, recuperacao = 0, reprovados = 0;

    printf("Quantos alunos existem na turma? ");
    scanf("%d", &qtd_alunos);

    for (int i = 1; i <= qtd_alunos; i++) {
        printf("Digite a nota do aluno %d: ", i);
        scanf("%f", &nota);

        soma_notas += nota;

        // Classificação
        if (nota >= 7.0) {
            aprovados++;
        } else if (nota >= 5.0) {
            recuperacao++;
        } else {
            reprovados++;
        }
    }

    // Cálculo da média (evitando divisão por zero)
    media = (qtd_alunos > 0) ? (soma_notas / qtd_alunos) : 0;

    printf("\n------------------------------\n");
    printf("Media da turma: %.2f\n", media);
    printf("Aprovados (>= 7): %d\n", aprovados);
    printf("Recuperacao (5 a 6.9): %d\n", recuperacao);
    printf("Reprovados (< 5): %d\n", reprovados);

    return 0;
}
